FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json tsconfig.json ./
RUN npm ci
COPY TitanUp_V2.ts ./
RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
COPY package*.json ./
RUN npm ci --omit=dev
COPY --from=builder /app/dist ./dist
# MCP stdio servers need npx available
RUN npm install -g npx

ENTRYPOINT ["node", "dist/TitanUp_V2.js"]
CMD []
